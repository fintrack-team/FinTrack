{
  "name": "fintrack-bot",
  "version": "0.1.0",
  "description": "Fintrack Telegram bot.",
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "nodejs",
    "grammy",
    "telegram bot"
  ],
  "homepage": "https://github.com/BODMAT/FinTrack#readme",
  "bugs": {
    "url": "https://github.com/BODMAT/FinTrack/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BODMAT/FinTrack.git"
  },
  "license": "MIT",
  "author": "Makar Dzhehur",
  "type": "module",
  "main": "bot.js",
  "scripts": {
    "dev": "concurrently \"pnpm exec tsc -w\" \"nodemon\"",
    "build": "rimraf dist && pnpm exec tsc",
    "start": "node dist/bot.js",
    "prestart": "pnpm run build",
    "predev": "pnpm run build",
    "check-types": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.44.0",
    "ioredis": "5.11.1",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.3.1",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "13.1.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3"
  }
}
